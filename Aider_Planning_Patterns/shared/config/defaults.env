# Version-controlled defaults. Override by creating a .env at repo root.

# Ollama
: "${OLLAMA_MODEL:=qwen2.5-coder:14b}"
: "${OLLAMA_API_BASE:=http://127.0.0.1:11434}"

# Repos
: "${AIDER_REPO_URL:=https://github.com/Aider-AI/aider.git}"
: "${POLYGLOT_REPO_URL:=https://github.com/Aider-AI/polyglot-benchmark.git}"

# Baseline benchmark run defaults
: "${AIDER_BENCH_MODEL_PREFIX:=ollama_chat/}"
: "${AIDER_BENCH_EDIT_FORMAT:=diff}"
: "${AIDER_BENCH_THREADS:=4}"
: "${AIDER_BENCH_TRIES:=2}"
: "${AIDER_BENCH_SHUFFLE_TASKS:=1}"
: "${AIDER_BENCH_EXERCISES_SUBDIR:=polyglot-benchmark}"
: "${AIDER_BENCH_TASK_TIMEOUT_SECONDS:=900}"
: "${AIDER_BENCH_REQUIRE_BASELINE_PARITY:=1}"
: "${AIDER_BENCH_REQUIRE_PER_TASK_PARITY:=0}"

# Docker
: "${AIDER_BENCH_DOCKER_IMAGE:=aider-benchmark:local}"
