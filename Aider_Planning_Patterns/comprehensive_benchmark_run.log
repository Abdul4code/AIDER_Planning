 def rebase(input_base, digits, output_base):
-    pass
+    # Validate input base
+    if input_base < 2:
+        raise ValueError("input base must be >= 2")
+    
+    # Validate output base
+    if output_base < 2:
+        raise ValueError("output base must be >= 2")
+    
+    # Validate digits
+    for digit in digits:
+        if not (0 <= digit < input_base):
+            raise ValueError("all digits must satisfy 0 <= d < input base")
+    
+    # Convert from input base to decimal
+    decimal_number = sum(digit * (input_base ** power) for power, digit in 
enumerate(reversed(digits)))
+    
+    # Convert from decimal to output base
+    if decimal_number == 0:
+        return [0]
+    
+    result = []
+    while decimal_number > 0:
+        result.append(decimal_number % output_base)
+        decimal_number //= output_base
+    
+    return result[::-1]
```



