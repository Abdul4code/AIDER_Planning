# AIDER Benchmark Configuration

# Ollama (local)
# Using conditional assignment (:=) so orchestrator model switching takes precedence
: "${OLLAMA_MODEL:=qwen2.5-coder:7b-instruct}"
: "${OLLAMA_API_BASE:=http://127.0.0.1:11434}"

# Aider benchmark repos
AIDER_REPO_URL=https://github.com/Aider-AI/aider.git
POLYGLOT_REPO_URL=https://github.com/exercism/python.git

# Benchmark run configuration
AIDER_BENCH_MODEL_PREFIX=ollama/
AIDER_BENCH_EDIT_FORMAT=whole
AIDER_BENCH_THREADS=1
AIDER_BENCH_TRIES=2
AIDER_BENCH_RETRY_TIMEOUT=60
AIDER_BENCH_LLM_TIMEOUT=120
AIDER_BENCH_TASK_TIMEOUT_SECONDS=900

# Override context window if needed
AIDER_BENCH_NUM_CTX=30000

# Task ordering (0 = deterministic for reproducibility)
AIDER_BENCH_SHUFFLE_TASKS=0

# Number of tasks to run per pattern/model combo (default: 10, override via --tasks flag to orchestrator)
# Using conditional assignment (:=) so que orchestrator --tasks parameter takes precedence
: "${AIDER_BENCH_NUM_TESTS:=10}"

# Languages to test (empty = all languages found in benchmark)
# Using conditional assignment so command-line overrides are preserved
: "${AIDER_BENCH_LANGUAGES:=python}"

# Exercises location
AIDER_BENCH_EXERCISES_SUBDIR=polyglot-benchmark

# Docker configuration
AIDER_BENCH_DOCKER_IMAGE=aider-benchmark:local

# Decomposition specific
AIDER_BENCH_DECOMP_MAX_STEPS=4
AIDER_BENCH_REQUIRE_BASELINE_PARITY=0

# MultiPlan specific
AIDER_BENCH_NUM_PLANS=4
