# Copy to .env and edit as needed.
# All paths are relative to the repo root.

# Ollama (local)
OLLAMA_MODEL=qwen2.5-coder:7b-instruct
OLLAMA_API_BASE=http://127.0.0.1:11434

# Aider benchmark repos
AIDER_REPO_URL=https://github.com/Aider-AI/aider.git
# For old code-editing benchmark mode, mount Exercism Python corpus here.
POLYGLOT_REPO_URL=https://github.com/exercism/python.git

# Benchmark run configuration (Baseline)
# NOTE: For old leaderboard-style Ollama runs, use "ollama/<OLLAMA_MODEL>".
AIDER_BENCH_MODEL_PREFIX=ollama/
# Recommended for many Ollama/open models to reduce edit-format mismatch failures.
AIDER_BENCH_EDIT_FORMAT=whole
AIDER_BENCH_THREADS=1
# Number of times to attempt each exercise (benchmark harness --tries)
# Recommended: 1 for faster runs, 2 for a small second-chance boost.
AIDER_BENCH_TRIES=2
AIDER_BENCH_REQUEST_TIMEOUT=1800

# Cap Aider's internal retry backoff loops (seconds).
# Upstream benchmark sets this extremely high (24h). Keeping it small prevents a single
# stuck exercise from retrying "forever" after timeouts/provider errors.
AIDER_BENCH_RETRY_TIMEOUT=900

# Optional: override model context window sent to the provider (benchmark --num-ctx)
AIDER_BENCH_NUM_CTX=30000

# Task ordering controls (applies to sidecar baseline/decomposition harnesses)
# 1 = shuffle selected tasks, 0 = keep deterministic sorted order
AIDER_BENCH_SHUFFLE_TASKS=0

# Full old code-editing benchmark run (133 tasks):
# AIDER_BENCH_LANGUAGES=python
# Optional: run a smaller subset for quick smoke tests
# AIDER_BENCH_NUM_TESTS=10
# Optional: filter by keyword substring in the test path/name
# AIDER_BENCH_KEYWORDS=two-fer
# Kept as-is; the runner mounts the selected repo at this path.
AIDER_BENCH_EXERCISES_SUBDIR=polyglot-benchmark

# Docker image tag for the benchmark container (built from the cloned aider repo)
AIDER_BENCH_DOCKER_IMAGE=aider-benchmark:local

# Optional: pin a specific aider revision for reproducibility
# AIDER_REPO_REF=main
# POLYGLOT_REPO_REF=main
